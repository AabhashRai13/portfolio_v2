rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isPublishedPost(postId) {
      return get(/databases/$(database)/documents/posts/$(postId)).data.isPublished == true;
    }

    function isApprovedComment() {
      return resource.data.status == 'approved';
    }

    function validShortString(field, min, max) {
      return field is string && field.size() >= min && field.size() <= max;
    }

    match /posts/{postId} {
      allow read: if resource.data.isPublished == true;
      allow create, update, delete: if false;

      match /comments/{commentId} {
        allow read: if isPublishedPost(postId) && isApprovedComment();
        allow create: if isPublishedPost(postId)
          && request.resource.data.keys().hasOnly([
            'authorName',
            'message',
            'createdAt',
            'status',
          ])
          && validShortString(request.resource.data.authorName, 2, 50)
          && validShortString(request.resource.data.message, 4, 2000)
          && request.resource.data.status == 'pending'
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }

      match /likes/{likeId} {
        allow read: if isPublishedPost(postId);
        allow create: if isPublishedPost(postId)
          && request.resource.data.keys().hasOnly([
            'clientId',
            'createdAt',
          ])
          && validShortString(request.resource.data.clientId, 8, 120)
          && request.resource.data.clientId == likeId
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }

      match /views/{viewId} {
        allow read: if isPublishedPost(postId);
        allow create: if isPublishedPost(postId)
          && request.resource.data.keys().hasOnly([
            'sessionId',
            'createdAt',
          ])
          && validShortString(request.resource.data.sessionId, 8, 120)
          && request.resource.data.sessionId == viewId
          && request.resource.data.createdAt == request.time;
        allow update, delete: if false;
      }
    }
  }
}
